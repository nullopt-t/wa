# Waey Platform - Environment Variables

# MongoDB Atlas connection string (required)
# Get from: https://cloud.mongodb.com
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/waey?retryWrites=true&w=majority

# Redis (Render provides this automatically)
REDIS_URL=redis://localhost:6379

# JWT Secrets (generate with: openssl rand -base64 64)
JWT_SECRET=your_jwt_secret_here
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here

# Token expiration
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# Email (optional - for verification/password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@waey.com
SMTP_FROM_NAME=Waey Platform

# Google Gemini AI (optional - for chatbot)
GEMINI_API_KEY=your-gemini-api-key
