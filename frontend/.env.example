# Frontend Environment Variables
# Copy this file to .env and update the values for your environment

# Backend API URL (change in production)
# Example: http://localhost:4000 or https://api.yourdomain.com
VITE_API_URL=http://localhost:4000

# Socket.io URL (change in production)
# Example: http://localhost:4000 or https://api.yourdomain.com
VITE_SOCKET_URL=http://localhost:4000

# Proxy target for Vite dev server (change in production)
# This is used by vite.config.js to proxy API requests
VITE_PROXY_TARGET=http://localhost:4000
