# Database
DATABASE_URL=mongodb://<user>:<password>@<host>:<port>/<db>

# JWT
JWT_SECRET=<generate-a-secure-secret>
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=<generate-a-secure-secret>
REFRESH_TOKEN_EXPIRES_IN=30d
BCRYPT_SALT_ROUNDS=12

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<your-email>
SMTP_PASSWORD=<your-app-password>
SMTP_FROM_EMAIL=noreply@waey.com
SMTP_FROM_NAME=Waey Platform

# Google Gemini AI
GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=1000

# Groq AI (alternative provider)
GROQ_API_KEY=<your-groq-api-key>
GROQ_MODEL=llama-3.3-70b-versatile

# AI Provider Selection (gemini or groq, default: gemini)
AI_PROVIDER=gemini

# Server
PORT=4001
NODE_ENV=development
