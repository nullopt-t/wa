# Backend Environment Variables
# Copy this file to .env and update the values for your environment

# =============================================================================
# DATABASE
# =============================================================================

# MongoDB connection string
# Local: mongodb://admin:password@mongo:27017/waey?authSource=admin
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/waey?retryWrites=true&w=majority
DATABASE_URL=mongodb://admin:password@mongo:27017/waey?authSource=admin

# Redis connection string
# Local: redis://redis:6379
# Production: redis://your-redis-url:6379
REDIS_URL=redis://redis:6379

# =============================================================================
# JWT CONFIGURATION
# =============================================================================

# Generate secrets with: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_key_here_change_in_production
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here_change_in_production

# Token expiration times
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# =============================================================================
# EMAIL CONFIGURATION (Optional - for verification/password reset)
# =============================================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@waey.com
SMTP_FROM_NAME=Waey Platform

# =============================================================================
# AI CONFIGURATION (Optional - for chatbot)
# =============================================================================

GEMINI_API_KEY=your-gemini-api-key-here

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Client URL (for email links - change in production)
CLIENT_URL=http://localhost:3000

# API URL (for upload controller)
API_URL=http://localhost:4000

# Server port (internal - don't change)
PORT=3000

# =============================================================================
# ENVIRONMENT
# =============================================================================

NODE_ENV=development
