# Use node alpine image for smaller size
FROM node:18-alpine

WORKDIR /app

# Install dependencies
COPY package*.json ./
RUN npm install

# Copy the rest of the application code
COPY . .

# Install dependencies again (in case package.json changed)
RUN npm install

# Create upload directories
RUN mkdir -p ./data/uploads/posts ./data/uploads/articles

# Expose port 3000
EXPOSE 3000

# Default command
CMD ["npm", "run", "start:dev"]